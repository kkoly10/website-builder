# Public app URL
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Search engine verification tokens. Paste the value Google/Bing give you in
# their Search Console "verify ownership" flow. Both are optional — the
# meta tag is omitted when the env var is unset.
GOOGLE_SITE_VERIFICATION=
BING_SITE_VERIFICATION=

# Supabase
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
ADMIN_EMAILS=

# Stripe
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# Email
RESEND_API_KEY=
RESEND_FROM_EMAIL=
ALERT_TO_EMAIL=
NOTIFICATION_FROM_EMAIL=
ADMIN_NOTIFICATION_EMAIL=
# Physical mailing address — required by CAN-SPAM. Rendered in every
# email footer. Format: "CrecyStudio · 123 Main St, City, ST 00000".
MAILING_ADDRESS_LINE=
# Mailto target for List-Unsubscribe header on marketing-adjacent
# emails (nudges, post-launch check-ins). Falls back to
# NOTIFICATION_FROM_EMAIL when unset.
UNSUBSCRIBE_EMAIL=

# Supabase Send Email Hook secret (Authentication → Hooks → Send Email
# Hook in the Supabase dashboard). Required for branded auth emails;
# the hook endpoint refuses requests when this is unset.
SUPABASE_SEND_EMAIL_HOOK_SECRET=

# Discovery-call calendar integration (Google Calendar).
# Required for the booking flow to read availability + write events.
# Leave blank to skip calendar entirely (DB-only bookings still work,
# UI falls back to a free-text availability textarea).
#
# Two paste paths — pick whichever is easier:
#   1. (recommended) Paste the full service-account JSON file content
#      as GOOGLE_SERVICE_ACCOUNT_JSON. No formatting traps.
#   2. (legacy) Paste client_email and private_key separately into
#      GOOGLE_SERVICE_ACCOUNT_EMAIL + GOOGLE_SERVICE_ACCOUNT_KEY. The
#      key value tolerates literal \n escapes, real newlines, and
#      accidental wrapping double quotes.
#
# Both paths require GOOGLE_CALENDAR_ID. JSON wins if both are set.
GOOGLE_CALENDAR_ID=
GOOGLE_SERVICE_ACCOUNT_JSON=
GOOGLE_SERVICE_ACCOUNT_EMAIL=
GOOGLE_SERVICE_ACCOUNT_KEY=

# Admin ops chat model override. Defaults to OPS_PIE_MODEL when unset.
OPS_CHAT_MODEL=

# Storage bucket override for portal message attachments. Defaults to
# PORTAL_ASSETS_BUCKET when unset.
PORTAL_MESSAGES_BUCKET=

# Internal dashboard auth (single consolidated token — used by all /api/internal/* routes)
INTERNAL_DASHBOARD_TOKEN=
CRON_SECRET=

# AI/PIE models
OPENAI_API_KEY=
PIE_MODEL=gpt-5
PIE_OPENAI_MODEL=gpt-5-mini
OPS_PIE_MODEL=gpt-4.1-mini
OPS_PIE_USE_OPENAI=true

# Portal assets
PORTAL_ASSETS_BUCKET=portal-assets

# Agreement certificates (private PDF storage)
CERTIFICATES_BUCKET=certificates

# Optional: direct scheduling links for warm/deep estimate variants
NEXT_PUBLIC_CALENDLY_URL=
NEXT_PUBLIC_CALENDLY_15_URL=
NEXT_PUBLIC_CALENDLY_30_URL=

# Optional: alerting for non-GET internal route access
INTERNAL_ALERT_WEBHOOK=

# Sentry error monitoring. Server + browser DSNs live separately so
# you can disable browser transmission while keeping server reporting.
# Auth-token / org / project are only needed at build time for source
# map upload (skipped when missing — stack traces stay minified).
SENTRY_DSN=
NEXT_PUBLIC_SENTRY_DSN=
SENTRY_AUTH_TOKEN=
SENTRY_ORG=
SENTRY_PROJECT=
