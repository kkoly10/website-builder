# Public app URL
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Supabase
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
ADMIN_EMAILS=

# Stripe
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# Email
RESEND_API_KEY=
RESEND_FROM_EMAIL=
ALERT_TO_EMAIL=
NOTIFICATION_FROM_EMAIL=
ADMIN_NOTIFICATION_EMAIL=

# Internal dashboard auth (single consolidated token — used by all /api/internal/* routes)
INTERNAL_DASHBOARD_TOKEN=
CRON_SECRET=

# AI/PIE models
OPENAI_API_KEY=
PIE_MODEL=gpt-5
PIE_OPENAI_MODEL=gpt-5-mini
OPS_PIE_MODEL=gpt-4.1-mini
OPS_PIE_USE_OPENAI=true

# Portal assets
PORTAL_ASSETS_BUCKET=portal-assets

# Optional: direct scheduling links for warm/deep estimate variants
NEXT_PUBLIC_CALENDLY_URL=
NEXT_PUBLIC_CALENDLY_15_URL=
NEXT_PUBLIC_CALENDLY_30_URL=

# Optional: alerting for non-GET internal route access
INTERNAL_ALERT_WEBHOOK=
